<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="ActiveCampaign Affiliate Content Challenge — May 20 through June 30, 2026">
    <title>ActiveCampaign Affiliate Content Challenge</title>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=Arimo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --ac-blue-800: #004CFF;
            --ac-blue-100: #F3FAFF;
            --midnight-1000: #00002D;
            --midnight-900: #23314C;
            --midnight-800: #3B4861;
            --midnight-200: #E5E5E5;
            --midnight-100: #F9F9F9;
            --cream: #FFFCF5;
            --moss-600: #347C44;
            --moss-800: #255131;
            --moss-100: #EAF4EC;
            --dusk-600: #598796;
            --dusk-100: #F2FBFD;
            --midday-500: #F8CE65;
            --midday-300: #FFF3D8;
            --palm: #E3FF65;
        }

        body {
            font-family: 'IBM Plex Sans', sans-serif;
            background: var(--cream);
            color: var(--midnight-1000);
            line-height: 1.6;
        }

        /* HEADER */
        .header {
            background: var(--midnight-1000);
            padding: 0 1.5rem;
            height: 60px;
            display: flex;
            align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }
        .header-inner {
            max-width: 860px;
            width: 100%;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .logo { display: flex; align-items: center; gap: 10px; }
        .logo-wordmark {
            font-family: 'Arimo', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            color: white;
            letter-spacing: -0.01em;
        }
        .header-label {
            font-size: 0.8125rem;
            color: rgba(255,255,255,0.4);
        }

        /* HERO */
        .hero {
            background: var(--midnight-1000);
            padding: 64px 1.5rem 56px;
            position: relative;
            overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute;
            top: -80px; right: -80px;
            width: 420px; height: 420px;
            background: radial-gradient(circle, rgba(0,76,255,0.22) 0%, transparent 68%);
            pointer-events: none;
        }
        .hero::after {
            content: '';
            position: absolute;
            bottom: -60px; left: 5%;
            width: 280px; height: 280px;
            background: radial-gradient(circle, rgba(227,255,101,0.07) 0%, transparent 65%);
            pointer-events: none;
        }
        .hero-inner {
            max-width: 860px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }
        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(0,76,255,0.15);
            border: 1px solid rgba(0,76,255,0.3);
            color: #94BFF1;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 5px 14px;
            border-radius: 100px;
            margin-bottom: 24px;
        }
        .hero-eyebrow span { color: var(--palm); }
        .hero-title {
            font-family: 'Arimo', sans-serif;
            font-size: clamp(2rem, 5vw, 3rem);
            font-weight: 700;
            color: white;
            line-height: 1.08;
            letter-spacing: -0.03em;
            margin-bottom: 16px;
        }
        .hero-title em { font-style: normal; color: var(--palm); }
        .hero-subtitle {
            font-size: 1.0625rem;
            color: rgba(255,255,255,0.6);
            max-width: 560px;
            line-height: 1.6;
            margin-bottom: 36px;
        }

        /* PRIZE STRIP */
        .prize-strip {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }
        .prize-pill {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            padding: 12px 20px;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .prize-pill-value {
            font-family: 'Arimo', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--palm);
            letter-spacing: -0.02em;
            line-height: 1;
        }
        .prize-pill-label {
            font-size: 0.75rem;
            color: rgba(255,255,255,0.5);
            font-weight: 500;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        /* BODY */
        .body {
            max-width: 860px;
            margin: 0 auto;
            padding: 48px 1.5rem 64px;
        }

        .section-label {
            font-size: 0.6875rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--ac-blue-800);
            margin-bottom: 10px;
        }
        .section-title {
            font-family: 'Arimo', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--midnight-1000);
            letter-spacing: -0.02em;
            margin-bottom: 6px;
        }
        .section-lead {
            font-size: 0.9375rem;
            color: var(--midnight-800);
            line-height: 1.65;
            margin-bottom: 28px;
            max-width: 680px;
        }

        .divider {
            border: none;
            border-top: 1px solid var(--midnight-200);
            margin: 40px 0;
        }

        /* HOW IT WORKS */
        .steps {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 40px;
        }
        .step {
            background: white;
            border: 1px solid var(--midnight-200);
            border-radius: 10px;
            padding: 20px;
        }
        .step-num {
            font-family: 'Arimo', sans-serif;
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--ac-blue-800);
            letter-spacing: -0.03em;
            line-height: 1;
            margin-bottom: 10px;
            opacity: 0.25;
        }
        .step-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--midnight-1000);
            margin-bottom: 6px;
        }
        .step-body {
            font-size: 0.8125rem;
            color: var(--midnight-800);
            line-height: 1.55;
        }

        /* TOPICS */
        .topic-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 40px;
        }
        .topic-card {
            background: white;
            border: 1px solid var(--midnight-200);
            border-radius: 10px;
            overflow: hidden;
        }
        .topic-header {
            padding: 16px 20px;
            color: white;
        }
        .topic-header.blue { background: var(--midnight-1000); }
        .topic-header.moss { background: var(--moss-800); }
        .topic-eyebrow {
            font-size: 0.6875rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            opacity: 0.55;
            margin-bottom: 4px;
        }
        .topic-name {
            font-family: 'Arimo', sans-serif;
            font-size: 1.125rem;
            font-weight: 700;
            letter-spacing: -0.01em;
        }
        .topic-body { padding: 16px 20px; }
        .topic-desc {
            font-size: 0.875rem;
            color: var(--midnight-900);
            line-height: 1.6;
            margin-bottom: 12px;
        }
        .topic-link {
            font-size: 0.8125rem;
            font-weight: 600;
            color: var(--ac-blue-800);
            text-decoration: none;
        }
        .topic-link:hover { text-decoration: underline; }

        /* REQUIREMENTS */
        .req-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 16px;
        }
        .req-card {
            background: white;
            border: 1px solid var(--midnight-200);
            border-radius: 10px;
            padding: 20px 22px;
        }
        .req-card-title {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--midnight-1000);
            margin-bottom: 12px;
        }
        .req-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .req-list li {
            font-size: 0.8125rem;
            color: var(--midnight-900);
            line-height: 1.5;
            padding-left: 18px;
            position: relative;
        }
        .req-list li::before {
            content: '✓';
            position: absolute;
            left: 0;
            color: var(--moss-600);
            font-weight: 700;
        }
        .req-list li.no::before {
            content: '✗';
            color: #C30000;
        }

        /* CALLOUTS */
        .callout {
            padding: 20px 24px;
            border-radius: 10px;
            border-left: 4px solid;
            margin-bottom: 24px;
        }
        .callout-primary { background: var(--ac-blue-100); border-color: var(--ac-blue-800); }
        .callout-warning { background: var(--midday-300); border-color: var(--midday-500); }
        .callout-success { background: var(--moss-100); border-color: var(--moss-600); }
        .callout-info { background: var(--dusk-100); border-color: var(--dusk-600); }
        .callout strong {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--midnight-1000);
            margin-bottom: 6px;
        }
        .callout p { font-size: 0.875rem; color: var(--midnight-900); line-height: 1.6; }
        .callout ul { margin-left: 1.25rem; margin-top: 6px; }
        .callout li { font-size: 0.875rem; color: var(--midnight-900); line-height: 1.6; margin-bottom: 4px; }
        .callout a { color: var(--ac-blue-800); font-weight: 600; }

        /* CTA BLOCK */
        .cta-block {
            background: var(--midnight-1000);
            border-radius: 12px;
            padding: 40px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        .cta-block::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 240px; height: 240px;
            background: radial-gradient(circle, rgba(0,76,255,0.25) 0%, transparent 65%);
            pointer-events: none;
        }
        .cta-block h3 {
            font-family: 'Arimo', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: white;
            letter-spacing: -0.02em;
            margin-bottom: 12px;
            position: relative;
        }
        .cta-block p {
            font-size: 0.9375rem;
            color: rgba(255,255,255,0.65);
            line-height: 1.65;
            max-width: 560px;
            margin: 0 auto 12px;
            position: relative;
        }
        .cta-note {
            font-size: 0.8125rem;
            color: rgba(255,255,255,0.35);
            position: relative;
        }

        /* FOOTER */
        .footer {
            text-align: center;
            padding: 32px 1.5rem;
            border-top: 1px solid var(--midnight-200);
            font-size: 0.8125rem;
            color: var(--midnight-800);
        }
        .footer a { color: var(--ac-blue-800); }

        @media (max-width: 700px) {
            .steps { grid-template-columns: 1fr 1fr; }
            .topic-grid { grid-template-columns: 1fr; }
            .req-grid { grid-template-columns: 1fr; }
            .hero { padding: 48px 1.25rem 40px; }
            .body { padding: 36px 1.25rem 48px; }
            .cta-block { padding: 28px 20px; }
        }
    </style>
</head>
<body>

<header class="header">
    <div class="header-inner">
