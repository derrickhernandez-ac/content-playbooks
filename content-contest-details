            <li><strong>July 20:</strong> Winners notified directly with payout details by this date</li>
        </ul>
    </div>

    <hr class="divider">

    <!-- RESOURCES -->
    <p class="section-label">Resources</p>
    <h2 class="section-title">Everything you need to create great content</h2>
